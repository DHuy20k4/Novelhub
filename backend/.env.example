# Database (SQL Server)
DATABASE_URL="sqlserver://localhost:1433;database=TruyenDB;user=sa;password=YOUR_PASSWORD;trustServerCertificate=true"

# JWT Authentication
JWT_SECRET="your_jwt_secret_key_here"
JWT_EXPIRES_IN="7d"

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
